{
  "name": "Benchmark Intelligence",
  "description": "AI agent that discovers trending models and tracks benchmark usage across LLMs, VLMs, and audio-language models",
  "version": "1.0.0",
  "agents": {
    "benchmark-intelligence": {
      "description": "Main benchmark tracking agent",
      "entrypoint": "agents/benchmark_intelligence/main.py",
      "type": "python",
      "requires": [
        "HF_TOKEN",
        "ANTHROPIC_API_KEY"
      ]
    }
  },
  "workflows": {
    "scan-benchmarks": {
      "description": "Discover models and track benchmarks",
      "agent": "benchmark-intelligence",
      "schedule": "0 9 1 * *"
    },
    "filter_models": {
      "description": "Stage 1: Filter trending models from target labs",
      "agent": "benchmark-intelligence",
      "command": "filter_models",
      "args": []
    },
    "find_docs": {
      "description": "Stage 2: Find documentation URLs for filtered models",
      "agent": "benchmark-intelligence",
      "command": "find_docs",
      "args": []
    },
    "parse_docs": {
      "description": "Stage 3: Parse documents and extract benchmarks",
      "agent": "benchmark-intelligence",
      "command": "parse_docs",
      "args": [
        {
          "name": "concurrency",
          "type": "int",
          "description": "Number of concurrent workers (default: 20)",
          "default": 20,
          "flag": "--concurrency"
        }
      ]
    },
    "consolidate_benchmarks": {
      "description": "Stage 4: Consolidate and deduplicate benchmark names",
      "agent": "benchmark-intelligence",
      "command": "consolidate_benchmarks",
      "args": [
        {
          "name": "from_db",
          "type": "boolean",
          "description": "Load from database instead of JSON files",
          "default": false,
          "flag": "--from-db"
        }
      ]
    },
    "categorize_benchmarks": {
      "description": "Stage 5: Categorize benchmarks using AI",
      "agent": "benchmark-intelligence",
      "command": "categorize_benchmarks",
      "args": []
    },
    "report": {
      "description": "Stage 6: Generate comprehensive benchmark reports",
      "agent": "benchmark-intelligence",
      "command": "report",
      "args": []
    },
    "generate": {
      "description": "Full pipeline: Run all 6 stages sequentially",
      "agent": "benchmark-intelligence",
      "command": "generate",
      "args": [
        {
          "name": "concurrency",
          "type": "int",
          "description": "Number of concurrent workers for parsing (default: 20)",
          "default": 20,
          "flag": "--concurrency"
        }
      ]
    }
  }
}
